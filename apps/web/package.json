{
  "name": "@bp-tracker/web",
  "version": "0.2.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173 --strictPort",
    "build": "vue-tsc -b && vite build",
    "typecheck": "vue-tsc -b --noEmit",
    "lint": "npm run typecheck",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@bp-tracker/contracts": "file:../../packages/contracts",
    "@lucide/vue": "^1.23.0",
    "vue": "^3.5.39",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/tsconfig": "^0.9.1",
    "jsdom": "^29.1.1",
    "typescript": "6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  }
}
