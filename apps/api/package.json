{
  "name": "@bp-tracker/api",
  "version": "0.2.7",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "predev": "npm run prisma:generate",
    "dev": "tsx watch src/index.ts",
    "prebuild": "npm run prisma:generate",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "pretypecheck": "npm run prisma:generate",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "npm run typecheck",
    "pretest": "npm run prisma:generate",
    "test": "vitest run",
    "pretest:coverage": "npm run prisma:generate",
    "test:coverage": "vitest run --coverage",
    "prisma:generate": "prisma generate --config prisma.config.ts",
    "prisma:migrate": "prisma migrate deploy --config prisma.config.ts",
    "prisma:push": "prisma db push --config prisma.config.ts",
    "prisma:dev": "prisma migrate dev --config prisma.config.ts",
    "preseed": "npm run prisma:generate",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@bp-tracker/contracts": "file:../../packages/contracts",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "pg": "^8.22.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/node": "^24.13.3",
    "@types/pg": "^8.15.6",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.10",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.9"
  }
}
