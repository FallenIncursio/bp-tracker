NODE_ENV=development
PUBLIC_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:5173
# Native PostgreSQL often uses localhost:5432.
# If you connect from the host to docker-compose.dev.yml Postgres, use localhost:5433.
DATABASE_URL=postgresql://bp_tracker:bp_tracker@localhost:5432/bp_tracker
DIRECT_DATABASE_URL=postgresql://bp_tracker:bp_tracker@localhost:5432/bp_tracker
SESSION_SECRET=change-this-session-secret
COOKIE_NAME=bp_tracker_session
FIRST_ADMIN_SETUP_TOKEN=
PORT=3000
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback
DISCORD_OAUTH_STATE_SECRET=change-this-discord-state-secret
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_GUILD_IDS=
VITE_GITHUB_URL=https://github.com/FallenIncursio/bp-tracker
VITE_PROJECT_HOMEPAGE_URL=https://bp-tracker.arcenciel.io
